# ============================================================
# Disaster Management AI - Environment Configuration Template
# ============================================================
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Replace all placeholder values with your actual API keys
# 3. NEVER commit .env to version control (it's in .gitignore)
# 4. Keep your .env file secure and don't share it
#
# ============================================================

# --- REQUIRED: Database Configuration ---
# Neon Postgres Database Connection String
# Get this from: https://console.neon.tech/
# Format: postgresql://username:password@hostname/database?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require

# --- REQUIRED: Twitter API Configuration ---
# Twitter Bearer Token for accessing Twitter v2 API
# Get this from: https://developer.twitter.com/en/portal/dashboard
# Required for: twitter_moniter_3.py (live tweet collection)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# --- REQUIRED: Google Gemini API Configuration ---
# Google AI API Key for text classification and extraction
# Get this from: https://makersuite.google.com/app/apikey
# Required for: tweet_classify.py, tweet_processer_2.py, sms_processer.py, sms_geocoder_3.py
GOOGLE_API_KEY=your_google_api_key_here

# --- REQUIRED: OpenCage Geocoding API Configuration ---
# OpenCage Data API Key for converting locations to coordinates
# Get this from: https://opencagedata.com/api
# Required for: geocode_events.py, sms_geocoder_3.py
OPENCAGE_API_KEY=your_opencage_api_key_here

# --- OPTIONAL: Flask/API Server Configuration ---
# Development or production mode
FLASK_ENV=development
FLASK_DEBUG=False

# API Server host and port
API_HOST=0.0.0.0
API_PORT=5000

# --- OPTIONAL: Twitter Monitoring Configuration ---
# Interval between tweet searches (in seconds)
TWITTER_SEARCH_INTERVAL=120

# Comma-separated list of disaster types to monitor
DISASTER_TYPES=earthquake,cyclone,flood,wildfire,resonance

# --- OPTIONAL: Location Configuration ---
# Target country for monitoring
TARGET_COUNTRY=India

# Target region/city for disaster monitoring
TARGET_REGION=Vellore
